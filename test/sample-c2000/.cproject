<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<?fileVersion 4.0.0?><cproject storage_type_id="org.eclipse.cdt.core.XmlProjectDescriptionStorage">
	<storageModule moduleId="org.eclipse.cdt.core.settings">
		<cconfiguration id="com.ti.ccstudio.buildDefinitions.C2000.Debug.1234567890">
			<storageModule buildSystemId="org.eclipse.cdt.managedbuilder.core.configurationDataProvider" id="com.ti.ccstudio.buildDefinitions.C2000.Debug.1234567890" moduleId="org.eclipse.cdt.core.settings" name="Debug">
				<externalSettings/>
				<extensions>
					<extension id="com.ti.ccstudio.binaryparser.CoffParser" point="org.eclipse.cdt.core.BinaryParser"/>
					<extension id="org.eclipse.cdt.core.GmakeErrorParser" point="org.eclipse.cdt.core.ErrorParser"/>
					<extension id="com.ti.ccstudio.errorparser.CoffErrorParser" point="org.eclipse.cdt.core.ErrorParser"/>
					<extension id="com.ti.ccstudio.errorparser.LinkErrorParser" point="org.eclipse.cdt.core.ErrorParser"/>
					<extension id="com.ti.ccstudio.errorparser.AsmErrorParser" point="org.eclipse.cdt.core.ErrorParser"/>
				</extensions>
			</storageModule>
			<storageModule moduleId="cdtBuildSystem" version="4.0.0">
				<configuration artifactExtension="out" artifactName="${ProjName}" buildProperties="" cleanCommand="${CG_CLEAN_CMD}" description="" id="com.ti.ccstudio.buildDefinitions.C2000.Debug.1234567890" name="Debug" parent="com.ti.ccstudio.buildDefinitions.C2000.Debug">
					<folderInfo id="com.ti.ccstudio.buildDefinitions.C2000.Debug.1234567890." name="/" resourcePath="">
						<toolChain id="com.ti.ccstudio.buildDefinitions.C2000.ToolChain.1234567890" name="TI Build Tools" superClass="com.ti.ccstudio.buildDefinitions.C2000.ToolChain">
							<option id="com.ti.ccstudio.buildDefinitions.core.OPT_TAGS.1234567890" superClass="com.ti.ccstudio.buildDefinitions.core.OPT_TAGS" valueType="stringList">
								<listOptionValue builtIn="false" value="DEVICE_CONFIGURATION_ID=TMS320F28377D"/>
								<listOptionValue builtIn="false" value="OUTPUT_FORMAT=COFF"/>
								<listOptionValue builtIn="false" value="RUNTIME_SUPPORT_LIBRARY=libc.a"/>
							</option>
							<targetPlatform id="com.ti.ccstudio.buildDefinitions.C2000.TargetPlatform.1234567890" name="Platform" superClass="com.ti.ccstudio.buildDefinitions.C2000.TargetPlatform"/>
							<builder buildPath="${workspace_loc:/sample-c2000}/Debug" id="com.ti.ccstudio.buildDefinitions.C2000.Builder.1234567890" managedBuildOn="true" name="GNU Make.Debug" superClass="com.ti.ccstudio.buildDefinitions.C2000.Builder"/>
							<tool id="com.ti.ccstudio.buildDefinitions.C2000.Compiler.1234567890" name="C2000 Compiler" superClass="com.ti.ccstudio.buildDefinitions.C2000.Compiler">
								<option id="com.ti.ccstudio.buildDefinitions.C2000.Compiler.OPT_LEVEL.1234567890" superClass="com.ti.ccstudio.buildDefinitions.C2000.Compiler.OPT_LEVEL" value="com.ti.ccstudio.buildDefinitions.C2000.Compiler.OPT_LEVEL.off" valueType="enumerated"/>
								<inputType id="com.ti.ccstudio.buildDefinitions.C2000.Compiler.InputType.1234567890" name="C2000 Compiler" superClass="com.ti.ccstudio.buildDefinitions.C2000.Compiler.InputType"/>
							</tool>
							<tool id="com.ti.ccstudio.buildDefinitions.C2000.Linker.1234567890" name="C2000 Linker" superClass="com.ti.ccstudio.buildDefinitions.C2000.Linker">
								<option id="com.ti.ccstudio.buildDefinitions.C2000.Linker.OUTPUT_FILE.1234567890" superClass="com.ti.ccstudio.buildDefinitions.C2000.Linker.OUTPUT_FILE" value="${ProjName}.out" valueType="string"/>
								<inputType id="com.ti.ccstudio.buildDefinitions.C2000.Linker.InputType.1234567890" name="C2000 Linker" superClass="com.ti.ccstudio.buildDefinitions.C2000.Linker.InputType">
									<additionalInput kind="additionalinputdependency" paths="$(USER_OBJS)"/>
									<additionalInput kind="additionalinput" paths="$(LIBS)"/>
								</inputType>
							</tool>
						</toolChain>
					</folderInfo>
				</configuration>
			</storageModule>
		</cconfiguration>
	</storageModule>
</cproject>
